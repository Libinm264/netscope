# ── Rust ──────────────────────────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock           # top-level; keep crate-level locks

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
dist/
.cache/

# ── Tauri ─────────────────────────────────────────────────────────────────────
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/src-tauri/WixTools/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
*.dmg

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.iml

# ── Secrets / local config ────────────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── NetScope session files ────────────────────────────────────────────────────
*.nscope

# ── Build artefacts ───────────────────────────────────────────────────────────
*.deb
*.rpm
*.AppImage
*.msi
*.exe

# ── Vite / Next.js build caches ──────────────────────────────────────────────
desktop/.vite/
hub/web/.next/
hub/web/tsconfig.tsbuildinfo
hub/web/next-env.d.ts

# ── GeoIP tarballs and databases (binary — extract to ~/.netscope/ instead) ──
*.tar.gz
*.mmdb

# ── Misc generated lockfiles ─────────────────────────────────────────────────
hub/web/package-lock.json
