<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime — required for Apple notarization (macOS 10.15+) -->

    <!-- Allow outbound network connections to the NetScope hub -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- WebKit / WKWebView requires this for the Tauri frontend -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Tauri IPC bridge uses unsigned memory pages -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Disable library validation so Tauri can load its own frameworks -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
