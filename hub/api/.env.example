# ── NetScope Hub API — Environment Variables ──────────────────────────────────
#
# Copy this file to .env and fill in your values before starting the server.
# In production, prefer setting these via your secrets manager or container
# environment rather than a .env file on disk.
#
# REQUIRED FOR PRODUCTION
# ────────────────────────────────────────────────────────────────────────────

# Bootstrap admin API key — required; set to a long random string.
# Generate with: openssl rand -hex 32
API_KEY=

# ClickHouse connection DSN — required; do NOT use the default credentials.
# Format: clickhouse://<user>:<password>@<host>:<port>/<database>
CLICKHOUSE_DSN=clickhouse://netscope:<STRONG_PASSWORD>@clickhouse:9000/netscope

# Comma-separated list of allowed CORS origins.
# MUST be set to your actual domain(s) in production.
# Example: ALLOWED_ORIGINS=https://hub.example.com
ALLOWED_ORIGINS=https://your-hub-domain.example.com

# Set to "true" to enforce all security checks at startup.
# With PRODUCTION=true the server will REFUSE to start if any of the above
# are left at their insecure defaults.
PRODUCTION=true

# ── OPTIONAL ────────────────────────────────────────────────────────────────

# Port the API server listens on (default: 8080)
PORT=8080

# Kafka / Redpanda brokers (comma-separated).  Leave empty to write flows
# directly to ClickHouse without a Kafka intermediary.
KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=netscope.flows

# MaxMind GeoLite2 database paths for geo enrichment.
# Download free from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
GEOIP_CITY_DB=/data/geoip/GeoLite2-City.mmdb
GEOIP_ASN_DB=/data/geoip/GeoLite2-ASN.mmdb

# AbuseIPDB API key for real-time threat lookups.
# Leave empty to use only the local CIDR blocklist heuristics.
ABUSEIPDB_KEY=

# Path to a newline-delimited CIDR blocklist file.
THREAT_BLOCKLIST=/data/blocklist.txt

# Optional bearer token to protect the /metrics Prometheus endpoint.
# If set, Prometheus scrape jobs must include: Authorization: Bearer <token>
# Leave empty to allow unauthenticated scraping (only safe on private networks).
METRICS_TOKEN=
