# ── NetScope Hub — Environment Variables ──────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Set API_KEY to a random secret:  openssl rand -hex 32
# 3. Start the stack:  docker compose up -d
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# API key for agents and the dashboard (generate: openssl rand -hex 32)
API_KEY=changeme

# ── Database (auto-configured in Docker Compose — change for external DB) ─────

CLICKHOUSE_DSN=clickhouse://netscope:netscope_pass@clickhouse:9000/netscope
CLICKHOUSE_PASSWORD=netscope_pass

# ── Kafka / Redpanda (auto-configured in Docker Compose) ──────────────────────

KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=netscope.flows

# ── API server ────────────────────────────────────────────────────────────────

PORT=8080

# CORS: use your domain in production, * for local dev
ALLOWED_ORIGINS=*

# Public URL of this hub (used in alert emails and agent enrollment)
APP_URL=http://localhost

# Organisation name shown in alert emails
ORG_NAME=NetScope

# ── Next.js Web Dashboard ─────────────────────────────────────────────────────

# URL the browser uses to reach the Go API
# Local dev: http://localhost:8080
# Production (via Caddy): https://your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Auth0 (optional) ──────────────────────────────────────────────────────────
# Leave ALL FOUR blank to run without authentication (local/air-gapped).
# Set ALL FOUR to enable Auth0 SSO.
#
# Setup: https://manage.auth0.com → Applications → Create Application
#   Callback URL:  https://<your-domain>/api/auth/callback
#   Logout URL:    https://<your-domain>

# Random 32-char secret for session encryption (generate: openssl rand -hex 32)
AUTH0_SECRET=

# Your Auth0 tenant URL, e.g. https://your-tenant.us.auth0.com
AUTH0_ISSUER_BASE_URL=

# Application client ID (from Auth0 dashboard)
AUTH0_CLIENT_ID=

# Application client secret (keep this secret!)
AUTH0_CLIENT_SECRET=

# Public URL of this web app (used as base for Auth0 redirects)
AUTH0_BASE_URL=http://localhost

# ── Caddy (reverse proxy + automatic HTTPS) ───────────────────────────────────

# Local dev: leave as :80 (HTTP only)
# Production: set to your domain → Caddy gets a free Let's Encrypt cert
CADDY_HOSTNAME=:80

# Email for Let's Encrypt renewal notifications (required for HTTPS)
CADDY_EMAIL=

# ── GeoIP (optional) ──────────────────────────────────────────────────────────
# Download free databases from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# Place .mmdb files in a local directory and set paths below.
GEOIP_CITY_DB=
GEOIP_ASN_DB=

# ── Threat Intelligence (optional) ────────────────────────────────────────────

# AbuseIPDB API key for real-time IP reputation checks (https://www.abuseipdb.com)
ABUSEIPDB_KEY=

# ── Email Alerts (optional) ───────────────────────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Prometheus Metrics (optional) ─────────────────────────────────────────────

# Bearer token to protect the /metrics endpoint (leave blank to disable auth)
METRICS_TOKEN=
