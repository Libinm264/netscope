# ── NetScope Hub — Environment Variables ─────────────────────────────────────
# Copy to .env and fill in your values before starting the stack.

# Shared API key — agents and the web dashboard both use this
API_KEY=changeme

# ClickHouse connection DSN
CLICKHOUSE_DSN=clickhouse://netscope:netscope_pass@clickhouse:9000/netscope

# Redpanda / Kafka broker(s) (comma-separated for multiple)
KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=netscope.flows

# Go API server port
PORT=8080

# ── Next.js Web Dashboard ─────────────────────────────────────────────────────
# These are exposed to the browser, so don't put secrets here beyond the API key
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_KEY=changeme
