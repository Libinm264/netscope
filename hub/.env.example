# ── NetScope Hub — Environment Variables ─────────────────────────────────────
# Copy to .env and fill in your values before starting the stack.
# Lines beginning with # are comments — safe to leave as-is.

# ── Shared ────────────────────────────────────────────────────────────────────

# API key used by agents and the web dashboard (keep this secret in production)
API_KEY=changeme

# ── Go / Fiber API ────────────────────────────────────────────────────────────

# ClickHouse connection DSN
CLICKHOUSE_DSN=clickhouse://netscope:netscope_pass@clickhouse:9000/netscope

# Redpanda / Kafka broker(s) — comma-separated for multiple brokers
KAFKA_BROKERS=redpanda:9092
KAFKA_TOPIC=netscope.flows

# Go API server port (internal, accessed via Caddy in production)
PORT=8080

# CORS: allowed origins for browser clients (use your domain in production)
# Example: https://netscope.example.com
ALLOWED_ORIGINS=*

# ── Next.js Web Dashboard ─────────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are embedded in the browser bundle — don't put secrets here

# URL the browser uses to reach the Go API (via Caddy in production)
NEXT_PUBLIC_API_URL=http://localhost:8080

# API key sent from the browser — matches API_KEY above
NEXT_PUBLIC_API_KEY=changeme

# ── Auth0 (optional) ──────────────────────────────────────────────────────────
# Authentication is only enforced when ALL FOUR of these are set.
# Leave blank (or remove) to run without login in development / air-gapped envs.
#
# 1. Create an application in https://manage.auth0.com → Applications
# 2. Set the callback URL to: https://<your-domain>/api/auth/callback
# 3. Set the logout  URL to: https://<your-domain>
# 4. Copy the values below

# A random 32-char+ secret used to encrypt the session cookie
# Generate with: openssl rand -hex 32
AUTH0_SECRET=

# Your Auth0 tenant URL, e.g. https://your-tenant.us.auth0.com
AUTH0_ISSUER_BASE_URL=

# Application client ID (public)
AUTH0_CLIENT_ID=

# Application client secret (keep secret!)
AUTH0_CLIENT_SECRET=

# The public URL of this web app — used as the base for Auth0 redirects
AUTH0_BASE_URL=http://localhost

# ── Caddy (reverse proxy / HTTPS) ────────────────────────────────────────────
# In production set CADDY_HOSTNAME to your real domain — Caddy will obtain
# a Let's Encrypt certificate automatically.
# In local dev leave it as ":80" (plain HTTP on port 80).
CADDY_HOSTNAME=:80

# Email for Let's Encrypt certificate notifications (required for HTTPS)
CADDY_EMAIL=
