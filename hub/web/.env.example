# ── NetScope Hub Web (Next.js) — Environment Variables ────────────────────────
#
# Copy this file to .env.local and fill in your values.
# IMPORTANT: None of the variables below should have the NEXT_PUBLIC_ prefix.
# The API key must NEVER be exposed to the browser bundle.  All hub API calls
# are proxied through the Next.js server (app/api/proxy/[...path]/route.ts).
#
# ── REQUIRED ────────────────────────────────────────────────────────────────

# URL of the NetScope Hub Go API (server-side only — never sent to the browser)
HUB_API_URL=http://hub-api:8080

# API key for the hub (server-side only — never sent to the browser).
# Must match the API_KEY configured on the hub API server.
HUB_API_KEY=

# ── OPTIONAL: Auth0 (enterprise SSO) ────────────────────────────────────────
# Leave all four unset to run without authentication (suitable for internal
# deployments on a private network).  Set all four to enable Auth0 SSO.

# AUTH0_SECRET=<random 32+ char secret>   # openssl rand -hex 32
# AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=

# ── Next.js internal ────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-hub-domain.example.com
